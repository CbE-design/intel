
{
  "entities": {
    "SubjectProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubjectProfile",
      "type": "object",
      "description": "Represents a subject profile for background checks.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "idNumber": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Clear", "Review", "Pending"] },
        "lastCheck": { "type": "string", "format": "date-time" }
      }
    },
    "ResearchReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ResearchReport",
      "type": "object",
      "description": "A saved criminological research dossier.",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "assessment": { "type": "string" },
        "trendData": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "analyst": { "type": "string" }
      },
      "required": ["topic", "content", "timestamp"]
    },
    "AuditLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AuditLog",
      "type": "object",
      "description": "System operational logs.",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "analyst": { "type": "string" },
        "status": { "type": "string", "enum": ["Success", "Warning", "Info"] }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/subject_profiles/{id}": { "schema": "#/backend/entities/SubjectProfile", "description": "Subject profiles" },
    "/subject_profiles/{id}/audit_log/{logId}": { "schema": "#/backend/entities/AuditLog", "description": "Subject activity logs" },
    "/research_reports/{id}": { "schema": "#/backend/entities/ResearchReport", "description": "Global research dossiers" }
  }
}
