rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Subjects and their investigative data are accessible to all authenticated investigators
    match /subject_profiles/{subjectProfileId} {
      allow read, write: if isSignedIn();
      
      // Allow access to all sub-collections (background_checks, reports, location_data, audit_log)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /external_sources/{externalSourceId} {
      allow read: if true;
      allow write: if false;
    }

    match /background_check_external_sources/{backgroundCheckExternalSourceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}