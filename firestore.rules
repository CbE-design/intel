rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Subjects and their investigations are accessible to all authenticated investigators (including anonymous)
    match /subject_profiles/{subjectProfileId} {
      allow read, write: if isSignedIn();
      
      match /background_checks/{backgroundCheckId} {
        allow read, write: if isSignedIn();
        
        match /reports/{reportId} {
          allow read, write: if isSignedIn();
        }
      }
      
      match /location_data/{locationDataId} {
        allow read, write: if isSignedIn();
      }
    }

    match /external_sources/{externalSourceId} {
      allow read: if true;
      allow write: if false;
    }

    match /background_check_external_sources/{backgroundCheckExternalSourceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}